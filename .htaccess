# ============================================================
# AUREL ACADEMY — Cache rules
# Place this in public_html/. If you already have a .htaccess
# (e.g. from WordPress), just APPEND the content below.
# ============================================================

<IfModule mod_headers.c>
  # HTML : never cache. Browser always re-fetches.
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # CSS / JS / fonts / images : long cache.
  # Cache invalidation is handled by ?v=YYYYMMDDx in HTML.
  <FilesMatch "\.(css|js|woff2|woff|ttf|otf|svg|png|jpg|jpeg|webp|gif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html                 "access plus 0 seconds"
  ExpiresByType text/css                  "access plus 1 year"
  ExpiresByType application/javascript    "access plus 1 year"
  ExpiresByType font/woff2                "access plus 1 year"
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/webp                "access plus 1 year"
</IfModule>

# Gzip/Brotli compression for text assets
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml font/woff2
</IfModule>
